---
layout: null
---
[
{% for post in site.posts %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
    "tags": {{ post.tags | join: ", " | jsonify }},
    "kind": "post",
    "content": {{ post.content | strip_html | strip_newlines | replace: "  ", " " | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
{% for page in site.pages %}
  {% unless page.url == '/search/' or page.url == '/search.json' or page.url == '/404.html' or page.url == '/feed.xml' %}
  ,
  {
    "title": {{ page.title | default: page.url | jsonify }},
    "url": {{ page.url | relative_url | jsonify }},
    "date": "",
    "tags": {{ page.tags | join: ", " | jsonify }},
    "kind": "page",
    "content": {{ page.content | strip_html | strip_newlines | replace: "  ", " " | jsonify }}
  }
  {% endunless %}
{% endfor %}
]
